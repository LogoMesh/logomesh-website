# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.playwright-mcp/
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cursor — local skill installs (data + scripts; reinstall via uipro / marketplace)
.cursor/skills/

# Superpowers plugin — brainstorm sessions, preview HTML, server state
.superpowers/

# Python (e.g. skill helper scripts)
__pycache__/
*.py[cod]

# Private reference notes (local only)
/docs/refs-internal/
